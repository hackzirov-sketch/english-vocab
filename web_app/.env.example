NODE_ENV=production
PORT=4173

# Recommended: set only the hash in production.
# Generate it with:
# node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
APP_PASSWORD_HASH=sha256_password_hash

# Optional: use this only for local testing, not for public deploy.
# APP_PASSWORD=your-password

# Keep this default path when deploying the whole repository.
DB_PATH=../database/master_maximal_v14_openrouter_ready.db

# Optional AI features.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://your-render-app.onrender.com
OPENROUTER_X_TITLE=English Vocabulary Master Web

# Telegram Web App URL after deploy.
WEB_APP_URL=https://your-render-app.onrender.com
